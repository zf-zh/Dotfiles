<plist version="1.0">
  <dict>
  <key>Label</key>
  <string>com.local.japan.autossh</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/autossh</string>
    <string>-M</string>
    <string>0</string>
    <string>-q</string>
    <string>-N</string>
    <string>-o</string>

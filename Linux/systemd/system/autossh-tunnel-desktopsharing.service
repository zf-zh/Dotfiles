[Unit]
Description=AutoSSH Reverse Tunnel Service
After=network-online.target

[Service]
User=jz2024
Environment="AUTOSSH_GATETIME=0"
ExecStart=/usr/bin/autossh -M 0 -q -N -o "ServerAliveInterval 30" -o "ServerAliveCountMax 3" -o "BatchMode=yes" -R 23390:localhost:3390 JZ2026-Ubuntu-Japan
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
